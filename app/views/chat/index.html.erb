<div class="container-fluid py-2 chat-page-layout"
     data-controller="chat"
     data-chat-chat-ask-path-value="<%= chat_ask_path %>"
     data-chat-chat-id-value="<%= @chat_record&.id %>">
  <div class="row h-100">

    <!-- Sidebar so zoznamom chatov -->
    <div class="col-md-3 col-lg-2 h-100">
      <div class="card shadow h-100" style="overflow-y: auto;">
        <div class="card-header bg-primary text-white py-2">
          <strong>Konverzácie</strong>
        </div>
        <div class="card-body p-2">
          <%= button_to 'Nový chat', chat_new_path, method: :post, class: 'btn btn-success btn-sm w-100 mb-2' %>
          <div class="list-group list-group-flush">
            <% @chats.each do |chat| %>
              <% first_msg = chat.messages.where(role: 'user').order(:created_at).first %>
              <% label = first_msg ? first_msg.content.to_s.truncate(28) : chat.created_at.strftime("%d.%m. %H:%M") %>
              <div class="list-group-item p-1 d-flex align-items-center gap-1 <%= 'active' if @chat_record&.id == chat.id %>">
                <%= link_to label, chat_show_path(chat),
                      class: "flex-grow-1 text-decoration-none text-truncate small #{'text-white' if @chat_record&.id == chat.id}" %>
                <%= button_to '✕', "/chat/#{chat.id}", method: :delete,
                      data: { confirm: 'Naozaj zmazať?' },
                      class: 'btn btn-sm btn-danger py-0 px-1' %>
              </div>
            <% end %>
            <% if @chats.empty? %>
              <p class="text-muted small text-center mt-2">Žiadne konverzácie</p>
            <% end %>
          </div>
        </div>
      </div>
    </div>

    <!-- Hlavná plocha chatu -->
    <div class="col-md-9 col-lg-10 h-100">
      <div class="card shadow h-100">
        <div class="card-header bg-primary text-white py-2">
          <h5 class="mb-0">Chat s AI</h5>
        </div>
        <div class="card-body d-flex flex-column p-3 h-100">
          <div id="chat-messages" class="flex-grow-1 mb-3" style="overflow-y: auto; height: 0;" data-chat-target="messages">
            <% if @chat_history && @chat_history.any? %>
              <% @chat_history.each do |msg| %>
                <% next if msg[:content].blank? || msg[:role] == 'system' %>
                
                <% if msg[:role] == 'tool' %>
                  <% begin %>
                    <% chart_data = JSON.parse(msg[:content]) %>
                    <% if chart_data.is_a?(Hash) && chart_data['chart_type'] %>
                      <!-- Tool message with chart data - will be rendered by renderExistingCharts() -->
                      <div data-chart="<%= h(msg[:content]) %>"
                           class="alert alert-light border small text-muted p-2"
                           style="max-width: 500px;">
                        Loading chart...
                      </div>
                    <% else %>
                      <!-- Tool message without valid chart type: <%= chart_data.keys rescue "error" %> -->
                    <% end %>
                  <% rescue => e %>
                    <!-- JSON Parse Error in tool message: <%= e.message %> -->
                    <!-- Content snippet: <%= msg[:content].to_s.truncate(50) %> -->
                  <% end %>
                <% else %>
                  <!-- Regular user/ai messages -->
                  <div class="<%= msg[:role] == 'user' ? 'user' : 'ai' %>-message mb-3">
                    <p class="<%= msg[:role] == 'user' ? 'text-end' : 'text-start' %>">
                      <span class="<%= msg[:role] == 'user' ? 'bg-light' : 'bg-primary text-white' %> p-2 rounded d-inline-block">
                        <%= sanitize msg[:content] %>
                      </span>
                    </p>
                  </div>
                <% end %>
              <% end %>
            <% else %>
              <div class="text-muted text-center mt-4">
                <p>Vitajte v chate! Ako vám môžem pomôcť?</p>
              </div>
            <% end %>
          </div>
          <div class="mt-auto">
            <div class="input-group mb-2">
              <label for="prompt-input"></label>
              <input type="text" id="prompt-input" class="form-control" placeholder="Napíšte správu..."
                     data-chat-target="input" data-action="keypress->chat#sendMessageOnEnter">
              <button id="send-button" class="btn btn-primary"
                      data-chat-target="sendButton" data-action="click->chat#sendMessage">Odoslať</button>
            </div>
          </div>
        </div>
      </div>
    </div>

  </div>
</div>